Subject: [PATCH 1/3] ot6: expand ROM to 4MB, add bank F0 segment for OT6 code

First 3MB byte-identical to vanilla build (checksum aside); stub proc
proves the expanded bank links. All OT6 code/data will live in bank F0,
reached via jsl, keeping vanilla-bank edits to minimal hook shims.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 cfg/ff6-en.cfg             |  4 ++++
 src/battle/battle_main.asm |  1 +
 src/battle/ot6.asm         | 14 ++++++++++++++
 3 files changed, 19 insertions(+)
 create mode 100644 src/battle/ot6.asm

diff --git a/cfg/ff6-en.cfg b/cfg/ff6-en.cfg
index d512017..4483763 100644
--- a/cfg/ff6-en.cfg
+++ b/cfg/ff6-en.cfg
@@ -19,6 +19,8 @@ memory {
     bank_e7: start = $e70000, size = $60000, type = ro, fill = yes, fillval = $ff;
     bank_ed: start = $ed0000, size = $10000, type = ro, fill = yes, fillval = $ff;
     bank_ee: start = $ee0000, size = $20000, type = ro, fill = yes, fillval = $ff;
+# OT6: expanded ROM space (3MB -> 4MB); all new code/data lives here
+    bank_f0: start = $f00000, size = $100000, type = ro, fill = yes, fillval = $ff;
 }
 
 segments {
@@ -198,4 +200,6 @@ segments {
     world_data: load = bank_ee, type = ro;
     world_gfx: load = bank_ee, type = ro;
     world_sine: load = bank_ee, type = ro, offset = $01fef1;
+# bank_f0 (OT6)
+    ot6_code: load = bank_f0, type = ro;
 }
diff --git a/src/battle/battle_main.asm b/src/battle/battle_main.asm
index 4b4f632..fdc6cf0 100644
--- a/src/battle/battle_main.asm
+++ b/src/battle/battle_main.asm
@@ -16490,5 +16490,6 @@ MonsterSpecialAnim:
 
 ; cf/fe00
         .include "battle_cmd_prop.asm"
+        .include "ot6.asm"
 
 ; ------------------------------------------------------------------------------
diff --git a/src/battle/ot6.asm b/src/battle/ot6.asm
new file mode 100644
index 0000000..99b3ee3
--- /dev/null
+++ b/src/battle/ot6.asm
@@ -0,0 +1,14 @@
+; ------------------------------------------------------------------------------
+; OT6 — Octopath Traveler mechanics module
+;
+; All new code and data live in expanded bank $F0 (segment "ot6_code") and
+; are reached from vanilla banks via jsl. Keep vanilla-bank edits to minimal
+; hook shims so bank $C2 stays under its fixed segment offsets.
+; ------------------------------------------------------------------------------
+
+.segment "ot6_code"
+
+; test stub proving the expanded bank links and is callable from bank $C2
+.proc Ot6Ping
+        rtl
+.endproc
